    AutoPlaceCycleActive = false
    if AutoPlaceCycleThread then
        task.cancel(AutoPlaceCycleThread)
        AutoPlaceCycleThread = nil
    end
    SafeSetToggle(Toggles.AutoPlaceCycle, false)
end

local function StartAutoPlaceCycle()
    if AutoPlaceCycleActive then 
        StopAutoPlaceCycle()
        return
    end
    
    local hasSelected = false
    for _, selected in pairs(AutoEquipSelectedItems) do
        if selected then hasSelected = true break end
    end
    
    if not hasSelected then
        SafeSetToggle(Toggles.AutoPlaceCycle, false)
        return
    end
    
    AutoPlaceCycleActive = true
    AutoPlaceItemsPlaced = 0
    
    AutoPlaceCycleThread = task.spawn(function()
        while AutoPlaceCycleActive do
            local placedThisCycle = 0
            local usedItems = {}
            
            while placedThisCycle < 4 and AutoPlaceCycleActive do
                local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
                if not backpack then break end

                local found = false
                for _, item in ipairs(backpack:GetChildren()) do
                    if item:IsA("Tool") then
                        local itemKey = item:GetDebugId()
                        if AutoEquipSelectedItems[itemKey] and not usedItems[itemKey] then
                            if Humanoid then
                                Humanoid:EquipTool(item)
                                task.wait(0.2)
                            end
                            InsertItemHolding()
                            placedThisCycle = placedThisCycle + 1
                            AutoPlaceItemsPlaced = AutoPlaceItemsPlaced + 1
                            usedItems[itemKey] = true
                            task.wait(0.4)
                            found = true
                            break
                        end
                    end
                end

                if not found then
                    break
                end
            end
            
            if placedThisCycle < 4 then
                StopAutoPlaceCycle()
                break
            end
            
            if AutoRevealActive then
                local startTime = tick()
                while AutoPlaceCycleActive and tick() - startTime < 5100 do
                    task.wait(1)
                    if not AutoRevealActive then
                        StopAutoPlaceCycle()
                        break
                    end
                end
                
                if AutoPlaceCycleActive and AutoRevealActive then
                    RevealFuse()
                    task.wait(60)
                end
            else
                StopAutoPlaceCycle()
                break
            end
        end
        StopAutoPlaceCycle()
    end)
end

local function SetAutoPlaceCycle(state)
    if AutoPlaceCycleActive == state then return end
    if state then StartAutoPlaceCycle() else StopAutoPlaceCycle() end
end

