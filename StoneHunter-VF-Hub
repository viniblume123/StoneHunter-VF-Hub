local function StopFly()
    if FlyConnection then FlyConnection:Disconnect() FlyConnection = nil end
    if BodyVelocity then BodyVelocity:Destroy() BodyVelocity = nil end
    if BodyGyro then BodyGyro:Destroy() BodyGyro = nil end
    if Humanoid and Humanoid.Parent then Humanoid.PlatformStand = false end
end

local function StartFly()
    if not Character or not RootPart or not Humanoid then return end
    StopFly()
    BodyVelocity = Instance.new("BodyVelocity")
    BodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    BodyVelocity.Velocity = Vector3.zero
    BodyVelocity.Parent = RootPart
    BodyGyro = Instance.new("BodyGyro")
    BodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    BodyGyro.P = 100000
    BodyGyro.CFrame = Workspace.CurrentCamera.CFrame
    BodyGyro.Parent = RootPart
    FlyConnection = RunService.RenderStepped:Connect(function()
        if not FlyEnabled or not RootPart then return end
        local cam = Workspace.CurrentCamera
        local direction = Vector3.zero
        local speed = 70
        if MoveKeys.W then direction = direction + cam.CFrame.LookVector end
        if MoveKeys.S then direction = direction - cam.CFrame.LookVector end
        if MoveKeys.A then direction = direction - cam.CFrame.RightVector end
        if MoveKeys.D then direction = direction + cam.CFrame.RightVector end
        if MoveKeys.Space then direction = direction + Vector3.new(0, 1, 0) end
        if MoveKeys.LeftShift then direction = direction - Vector3.new(0, 1, 0) end
        if direction.Magnitude > 0 then direction = direction.Unit * speed end
        BodyVelocity.Velocity = direction
        BodyGyro.CFrame = cam.CFrame
    end)
end

