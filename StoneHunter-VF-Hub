local function FindRagdollRemote(char)
    if not char then return nil end
    local ragdoll = char:FindFirstChild("ragdoll")
    if ragdoll then
        local functions = ragdoll:FindFirstChild("functions")
        if functions then
            local r = functions:FindFirstChild("remoteragdoll")
            if r then return r end
        end
    end
    local function Search(obj)
        for _, c in pairs(obj:GetChildren()) do
            if c.Name == "remoteragdoll" and (c:IsA("RemoteFunction") or c:IsA("RemoteEvent")) then
                return c
            end
            if c:IsA("Folder") or c:IsA("Model") then
                local found = Search(c)
                if found then return found end
            end
        end
        return nil
    end
    return Search(char)
end

local function ExecuteRagdoll(player)
    if not player then return false end
    if ExcludedPlayers[player.Name] then return false end
    if player == LocalPlayer then return false end
    if MarkedPlayers[player.Name] == false then return false end

    local char = player.Character
    if not char then return false end

    local remote = FindRagdollRemote(char)
    if not remote then return false end

    return pcall(function()
        if remote:IsA("RemoteFunction") then
            remote:InvokeServer()
        else
            remote:FireServer()
        end
    end)
end

local function AtualizarFilaRagdoll()
    for i = #RagdollFila, 1, -1 do
        local p = RagdollFila[i]
        if not p or not p.Parent or ExcludedPlayers[p.Name] or p == LocalPlayer or MarkedPlayers[p.Name] == false then
            table.remove(RagdollFila, i)
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and not ExcludedPlayers[p.Name] and MarkedPlayers[p.Name] ~= false then
            local jaNaFila = false
            for _, f in pairs(RagdollFila) do
                if f == p then jaNaFila = true break end
            end
            if not jaNaFila then
                table.insert(RagdollFila, p)
                RagdollTentativasPorJogador[p.Name] = 0
            end
        end
    end
end

local function AdicionarPrioridadeRagdoll(player)
    if player == LocalPlayer then return end
    if ExcludedPlayers[player.Name] then return end
    if MarkedPlayers[player.Name] == false then return end
    if not RagdollRodando then return end

    for i = #RagdollFila, 1, -1 do
        if RagdollFila[i] == player then
            table.remove(RagdollFila, i)
            break
        end
    end
    table.insert(RagdollFila, 1, player)
    RagdollTentativasPorJogador[player.Name] = 0
end

local function ProcessarProximoRagdoll()
    if RagdollProcessando then return end
    local agora = tick()
    if agora - RagdollUltimoProcessamento < RagdollDelayEntreExecucoes then return end

    RagdollProcessando = true
    AtualizarFilaRagdoll()

    if #RagdollFila == 0 then
        RagdollProcessando = false
        return
    end

    local alvo = table.remove(RagdollFila, 1)
    if not alvo then
        RagdollProcessando = false
        return
    end

    local tentativas = RagdollTentativasPorJogador[alvo.Name] or 0
    local success = ExecuteRagdoll(alvo)

    if not success then
        tentativas = tentativas + 1
        RagdollTentativasPorJogador[alvo.Name] = tentativas
        if tentativas < 3 then
            table.insert(RagdollFila, alvo)
        end
    else
        RagdollTentativasPorJogador[alvo.Name] = 0
    end

    RagdollUltimoProcessamento = tick()
    RagdollProcessando = false
end

local function IniciarRagdoll()
    if RagdollRodando then return end
    RagdollRodando = true
    RagdollFila = {}
    RagdollTentativasPorJogador = {}
    AtualizarFilaRagdoll()
    RagdollUltimoProcessamento = 0

    if RagdollZoneActive then SetRagdollZoneState(false) end

    RagdollTarefa = task.spawn(function()
        while RagdollRodando do
            ProcessarProximoRagdoll()
            task.wait(RagdollDelayEntreExecucoes)
        end
    end)

    SafeSetToggle(Toggles.Ragdoll, true)
end

local function PararRagdoll()
    RagdollRodando = false
    if RagdollTarefa then task.cancel(RagdollTarefa) RagdollTarefa = nil end
    SafeSetToggle(Toggles.Ragdoll, false)
end

local function ToggleRagdoll()
    if RagdollRodando then PararRagdoll() else IniciarRagdoll() end
end

local function CreateZoneCircle()
    if ZoneCircle then ZoneCircle:Destroy() ZoneCircle = nil end
    if ZoneRing then ZoneRing:Destroy() ZoneRing = nil end
    if ZonePositionConnection then ZonePositionConnection:Disconnect() ZonePositionConnection = nil end

    if not RootPart then return end

    ZoneCircle = Instance.new("Part")
    ZoneCircle.Name = "RagdollZoneFill"
    ZoneCircle.Shape = Enum.PartType.Cylinder
    ZoneCircle.Size = Vector3.new(RagdollZoneRadius * 2, 0.2, RagdollZoneRadius * 2)
    ZoneCircle.Anchored = true
    ZoneCircle.CanCollide = false
    ZoneCircle.Material = Enum.Material.Neon
    ZoneCircle.Color = Color3.fromRGB(255, 0, 0)
    ZoneCircle.Transparency = 0.7
    ZoneCircle.Orientation = Vector3.new(0, 0, 90)
    ZoneCircle.Parent = Workspace

    ZoneRing = Instance.new("Part")
    ZoneRing.Name = "RagdollZoneRing"
    ZoneRing.Shape = Enum.PartType.Cylinder
    ZoneRing.Size = Vector3.new(RagdollZoneRadius * 2 + 0.5, 0.3, RagdollZoneRadius * 2 + 0.5)
    ZoneRing.Anchored = true
    ZoneRing.CanCollide = false
    ZoneRing.Material = Enum.Material.Neon
    ZoneRing.Color = Color3.fromRGB(255, 50, 50)
    ZoneRing.Transparency = 0.5
    ZoneRing.Orientation = Vector3.new(0, 0, 90)
    ZoneRing.Parent = Workspace

    ZonePositionConnection = RunService.Heartbeat:Connect(function()
        if not RagdollZoneActive or not RootPart or not ZoneCircle or not ZoneRing then return end
        local pos = RootPart.Position - Vector3.new(0, 3, 0)
        ZoneCircle.Position = pos
        ZoneRing.Position = pos
    end)
end

local function ProcessZoneRagdoll()
    if not RagdollZoneActive or not RootPart then return end

    local rootPos = RootPart.Position
    local flatRoot = Vector3.new(rootPos.X, 0, rootPos.Z)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not ExcludedPlayers[player.Name] and MarkedPlayers[player.Name] ~= false then
            local char = player.Character
            local targetRoot = char and char:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local flatTarget = Vector3.new(targetRoot.Position.X, 0, targetRoot.Position.Z)
                local distance = (flatRoot - flatTarget).Magnitude
                if distance <= RagdollZoneRadius then
                    if not ZonePlayers[player] then
                        ZonePlayers[player] = true
                        ExecuteRagdoll(player)
                    end
                else
                    ZonePlayers[player] = nil
                end
            end
        end
    end
end

local function SetRagdollZoneState(state)
    if state and RagdollRodando then
        SafeSetToggle(Toggles.RagdollZone, false)
        return
    end

    if RagdollZoneActive == state then return end
    RagdollZoneActive = state

    if state then
        CreateZoneCircle()
        if ZoneProcessThread then task.cancel(ZoneProcessThread) end
        ZoneProcessThread = task.spawn(function()
            while RagdollZoneActive do
                ProcessZoneRagdoll()
                task.wait(0.15)
            end
        end)
    else
        if ZoneCircle then ZoneCircle:Destroy() ZoneCircle = nil end
        if ZoneRing then ZoneRing:Destroy() ZoneRing = nil end
        if ZonePositionConnection then ZonePositionConnection:Disconnect() ZonePositionConnection = nil end
        if ZoneProcessThread then task.cancel(ZoneProcessThread) ZoneProcessThread = nil end
        ZonePlayers = {}
    end
    SafeSetToggle(Toggles.RagdollZone, state)
end

local function SetRagdollZoneRadius(value)
    RagdollZoneRadius = value
    if RagdollZoneActive then CreateZoneCircle() end
end

local function ConfigurarEventosRagdoll()
    local function OnPlayerDeathOrRespawn(player)
        if player == LocalPlayer then return end
        if ExcludedPlayers[player.Name] then return end
        if MarkedPlayers[player.Name] == false then return end
        if RagdollRodando then AdicionarPrioridadeRagdoll(player) end
    end

    local function ConfigurarPlayer(player)
        if player == LocalPlayer then return end

        player.CharacterAdded:Connect(function()
            task.wait(0.5)
            OnPlayerDeathOrRespawn(player)
        end)

        local function verificarMorte()
            if player.Character then
                local char = player.Character
                char.AncestryChanged:Connect(function()
                    if not char.Parent then OnPlayerDeathOrRespawn(player) end
                end)
            end
        end

        verificarMorte()
        player.CharacterAdded:Connect(verificarMorte)
    end

    for _, p in pairs(Players:GetPlayers()) do
        ConfigurarPlayer(p)
        if ExcludedPlayers[p.Name] == nil then ExcludedPlayers[p.Name] = false end
        if MarkedPlayers[p.Name] == nil then MarkedPlayers[p.Name] = true end
    end

    Players.PlayerAdded:Connect(function(p)
        ConfigurarPlayer(p)
        if ExcludedPlayers[p.Name] == nil then ExcludedPlayers[p.Name] = false end
        if MarkedPlayers[p.Name] == nil then MarkedPlayers[p.Name] = true end
        if RagdollRodando then AtualizarFilaRagdoll() end
        UpdateMarkedPlayersDropdown()
    end)

    Players.PlayerRemoving:Connect(function(p)
        for i = #RagdollFila, 1, -1 do
            if RagdollFila[i] == p then table.remove(RagdollFila, i) end
        end
        RagdollTentativasPorJogador[p.Name] = nil
        UpdateMarkedPlayersDropdown()
    end)
end

local function UpdateMarkedPlayersDropdown()
    if not MarkedPlayersDropdown then return end
    local options = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local isMarked = MarkedPlayers[p.Name] ~= false
            table.insert(options, p.Name .. (isMarked and " ✓" or " ✗"))
        end
    end
    MarkedPlayersDropdown:Refresh(options)
end

ConfigurarEventosRagdoll()

