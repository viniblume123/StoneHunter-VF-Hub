local function LoadConfig(name)
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(HUB_FOLDER .. "/" .. name .. ".json"))
    end)
    
    if success and data then
        if data.FlyEnabled ~= nil then SetFly(data.FlyEnabled) end
        if data.NoHoldEnabled ~= nil then SetNoHold(data.NoHoldEnabled) end
        if data.HighlightEnabled ~= nil then SetHighlight(data.HighlightEnabled) end
        if data.InfiniteJumpEnabled ~= nil then SetInfiniteJump(data.InfiniteJumpEnabled) end
        if data.TpToMouseEnabled ~= nil then SetTpToMouse(data.TpToMouseEnabled) end
        if data.AutoClickActive ~= nil then SetAutoClick(data.AutoClickActive) end
        if data.GravityValue then SetGravity(data.GravityValue) end
        if data.JumpPowerValue then SetJumpPower(data.JumpPowerValue) end
        if data.WalkSpeedValue then SetWalkSpeed(data.WalkSpeedValue) end
        if data.RagdollZoneRadius then SetRagdollZoneRadius(data.RagdollZoneRadius) end
        if data.AutoCollectLoopEnabled ~= nil then AutoCollectLoopEnabled = data.AutoCollectLoopEnabled end
        if data.AutoCollectSecondsDelay then AutoCollectSecondsDelay = data.AutoCollectSecondsDelay end
        if data.AutoCollectMinutesDelay then AutoCollectMinutesDelay = data.AutoCollectMinutesDelay end
        
        if data.ServerHopConfig then
            for k, v in pairs(data.ServerHopConfig) do
                ServerHopConfig[k] = v
            end
        end
        
        notify("Config", "Loaded: " .. name, 2)
        return true
    end
    
    return false
end

