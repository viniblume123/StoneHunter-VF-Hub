local function FindPartInside(instance)
    if not instance or not instance.Parent then return nil end
    if instance:IsA("BasePart") then return instance end
    for _, descendant in ipairs(instance:GetDescendants()) do
        if descendant:IsA("BasePart") then return descendant end
    end
    return nil
end

local function FindStoneByName(stoneName)
    local stones = {}
    for _, descendant in ipairs(Workspace:GetDescendants()) do
        if descendant.Name == stoneName and (descendant:IsA("Model") or descendant:IsA("Folder") or descendant:IsA("BasePart")) then
            local part = FindPartInside(descendant)
            if part then
                table.insert(stones, {container = descendant, part = part})
            end
        end
    end
    return stones
end

local function CreateStoneHighlight(stone, part, stoneName)
    if not HighlightEnabled then return end
    local highlight = Instance.new("Highlight")
    highlight.Adornee = stone
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    if stoneName == "DivineStone" then
        highlight.FillColor = Color3.fromRGB(255, 215, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 180, 0)
    else
        highlight.FillColor = Color3.fromRGB(0, 180, 255)
        highlight.OutlineColor = Color3.fromRGB(0, 130, 200)
    end
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0.2
    highlight.Parent = stone
    table.insert(StoneHighlights, highlight)

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = part
    billboard.Size = UDim2.new(0, 120, 0, 35)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = part

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = stoneName
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0.2
    textLabel.TextColor3 = stoneName == "DivineStone" and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(0, 180, 255)
    textLabel.Parent = billboard
    table.insert(StoneBillboards, billboard)
end

local function UpdateStoneHighlights()
    for _, highlight in pairs(StoneHighlights) do
        pcall(function() highlight:Destroy() end)
    end
    for _, billboard in pairs(StoneBillboards) do
        pcall(function() billboard:Destroy() end)
    end
    StoneHighlights = {}
    StoneBillboards = {}
    if not HighlightEnabled then return end
    for _, stoneName in ipairs(StonePriority) do
        local stones = FindStoneByName(stoneName)
        for _, stoneInfo in ipairs(stones) do
            CreateStoneHighlight(stoneInfo.container, stoneInfo.part, stoneName)
        end
    end
end

