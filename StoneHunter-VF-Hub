local options = {}
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        local isMarked = MarkedPlayers[p.Name] ~= false
        table.insert(options, p.Name .. (isMarked and " ✓" or " ✗"))
    end
end

MarkedPlayersDropdown = Tabs.Ragdoll:CreateDropdown({
    Name = "Mark Players (Ragdoll Target)",
    Options = options,
    CurrentOption = {},
    MultipleOptions = true,
    Flag = "MarkedPlayers",
    Callback = function(Options)
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local isMarked = false
                for _, opt in ipairs(Options) do
                    if opt:gsub(" [✓✗]$", "") == player.Name then
                        isMarked = true
                        break
                    end
                end
                MarkedPlayers[player.Name] = isMarked
                if RagdollRodando then
                    if isMarked then
                        AdicionarPrioridadeRagdoll(player)
                    else
                        for i, p in pairs(RagdollFila) do
                            if p == player then
                                table.remove(RagdollFila, i)
                                break
                            end
                        end
                    end
                end
            end
        end
        UpdateMarkedPlayersDropdown()
    end
})

