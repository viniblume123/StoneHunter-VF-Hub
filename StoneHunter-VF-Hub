local function AutoCollectOnce()
    local items = GetAllCollectTouch()
    if #items == 0 then return false end

    local originalPositions = {}
    local originalTransparency = {}
    local originalCanCollide = {}

    for _, item in ipairs(items) do
        originalPositions[item] = item.CFrame
        originalTransparency[item] = item.Transparency
        originalCanCollide[item] = item.CanCollide
    end

    for _, item in ipairs(items) do
        if item and item.Parent and RootPart then
            item.CFrame = RootPart.CFrame - Vector3.new(0, 3, 0)
        end
    end

    task.wait(0.5)

    for _, item in ipairs(items) do
        if item and item.Parent then
            item.CFrame = originalPositions[item]
            item.Transparency = originalTransparency[item]
            item.CanCollide = originalCanCollide[item]
            CollectedItems[item] = true
        end
    end

    return true
end

