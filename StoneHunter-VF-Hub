UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.W then MoveKeys.W = true end
    if input.KeyCode == Enum.KeyCode.A then MoveKeys.A = true end
    if input.KeyCode == Enum.KeyCode.S then MoveKeys.S = true end
    if input.KeyCode == Enum.KeyCode.D then MoveKeys.D = true end
    if input.KeyCode == Enum.KeyCode.Space then MoveKeys.Space = true end
    if input.KeyCode == Enum.KeyCode.LeftShift then MoveKeys.LeftShift = true end

    if input.KeyCode == Enum.KeyCode.Space and InfiniteJumpEnabled and Humanoid then
        Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end

    if input.KeyCode == Keybinds.Fly then
        SetFly(not FlyEnabled)
    elseif input.KeyCode == Keybinds.Ragdoll then
        ToggleRagdoll()
    elseif input.KeyCode == Keybinds.TpToStone then
        TpToBestStone()
    elseif input.KeyCode == Keybinds.ServerHop then
        SingleServerHop()
    elseif input.KeyCode == Keybinds.InfiniteJump then
        SetInfiniteJump(not InfiniteJumpEnabled)
    elseif input.KeyCode == Keybinds.AutoClick then
        SetAutoClick(not AutoClickActive)
    elseif input.KeyCode == Keybinds.TpSaved1 then
        if TeleportSpots[1] then TeleportToPosition(TeleportSpots[1]) end
    elseif input.KeyCode == Keybinds.TpSaved2 then
        if TeleportSpots[2] then TeleportToPosition(TeleportSpots[2]) end
    elseif input.KeyCode == Keybinds.TpSaved3 then
        if TeleportSpots[3] then TeleportToPosition(TeleportSpots[3]) end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then MoveKeys.W = false end
    if input.KeyCode == Enum.KeyCode.A then MoveKeys.A = false end
    if input.KeyCode == Enum.KeyCode.S then MoveKeys.S = false end
    if input.KeyCode == Enum.KeyCode.D then MoveKeys.D = false end
    if input.KeyCode == Enum.KeyCode.Space then MoveKeys.Space = false end
    if input.KeyCode == Enum.KeyCode.LeftShift then MoveKeys.LeftShift = false end
end)

