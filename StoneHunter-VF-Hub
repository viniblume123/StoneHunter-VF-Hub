local function CheckTargetStoneInCurrentServer()
    if ServerHopConfig.TargetStone == "DivineStone" then
        return #FindStoneByName("DivineStone") > 0
    elseif ServerHopConfig.TargetStone == "CelestialStone" then
        return #FindStoneByName("CelestialStone") > 0
    end
    return false
end

local function IsServerValid(server)
    if ServerHopConfig.IgnoreCurrentServer and server.id == game.JobId then return false end
    if ServerHopConfig.IgnoreFullServers and server.playing >= server.maxPlayers then return false end
    if ServerHopConfig.IgnoreVisitedServers and VisitedServers[server.id] then return false end
    return true
end

local function SortServers(servers)
    if ServerHopConfig.SortMode == "LowestPlayers" then
        table.sort(servers, function(a, b) return a.playing < b.playing end)
    elseif ServerHopConfig.SortMode == "HighestPlayers" then
        table.sort(servers, function(a, b) return a.playing > b.playing end)
    end
end

local function GetValidServers()
    local allServers = {}
    local cursor = nil
    
    for page = 1, ServerHopConfig.MaxPages do
        local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
        if cursor then url = url .. "&cursor=" .. cursor end
        
        local success, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        
        if success and result and result.data then
            for _, server in ipairs(result.data) do
                if IsServerValid(server) then
                    table.insert(allServers, server)
                end
            end
            cursor = result.nextPageCursor
            if not cursor then break end
        else
            break
        end
        task.wait(0.35)
    end
    
    SortServers(allServers)
    return allServers
end

local function HopToNextServer()
    if ServerHopBusy then return false end
    ServerHopBusy = true
    
    local servers = GetValidServers()
    local attempts = 0
    local successHop = false
    
    for _, server in ipairs(servers) do
        if attempts >= ServerHopConfig.MaxTeleportAttempts and not ServerHopConfig.RetryTeleportFail then
            break
        end
        
        attempts = attempts + 1
        VisitedServers[server.id] = true
        
        local ok = pcall(function()
            TeleportService:TeleportToPlaceInstance(PlaceId, server.id, LocalPlayer)
        end)
        
        if ok then
            successHop = true
            break
        end
    end
    
    ServerHopBusy = false
    return successHop
end

local function SingleServerHop()
    if ServerHopBusy then return end
    HopToNextServer()
end

