            if ServerHopConfig.HopOnlyIfNoStone then
                if CheckTargetStoneInCurrentServer() then
                    notify("Auto Hop", "Target stone found! Stopped.", 3)
                    ServerHopConfig.AutoHopEnabled = false
                    SafeSetToggle(Toggles.AutoHop, false)
                    break
                end
            end
            
            local ok = HopToNextServer()
            if not ok then
