local function MonitorStones()
    Workspace.DescendantAdded:Connect(function(obj)
        if obj.Name == "DivineStone" or obj.Name == "CelestialStone" then
            UpdateStoneHighlights()
            if StoneLabel then
                local container, _, stoneName = FindBestStone()
                if container then
                    StoneLabel:Set("Stone: " .. stoneName)
                end
            end
        end
    end)

    Workspace.DescendantRemoving:Connect(function(obj)
        if obj.Name == "DivineStone" or obj.Name == "CelestialStone" then
            UpdateStoneHighlights()
            local container, _, stoneName = FindBestStone()
            if container then
                StoneLabel:Set("Stone: " .. stoneName)
            else
                StoneLabel:Set("Stone: none")
            end
        end
    end)
end

